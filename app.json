{
  "expo": {
    "name": "Blacklist",
    "slug": "blacklist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icono.jpeg",
    "scheme": "blacklist",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icono.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.charlie.blacklist",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Te avisamos cuando alguien tenga una deuda pendiente o si hoy nadie te debe."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icono.jpeg",
        "backgroundColor": "#121212"
      },
      "package": "com.charlie.blacklist",
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icono.jpeg"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#FFFFFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
